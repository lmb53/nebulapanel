#!/usr/bin/env bash
#
# nebula-helper — the ONLY privileged surface of Nebula Panel.
# Installed root-owned to /usr/local/bin/nebula-helper with a single sudoers
# rule (www-data ALL=(root) NOPASSWD: /usr/local/bin/nebula-helper *).
#
# It performs a fixed, validated set of operations so the panel never needs a
# broad `tee`/`ln`/`mkdir`/`certbot` sudo grant. Every argument is validated
# here before use. Keep this file root-owned and NOT writable by the web user.
#
set -euo pipefail

NGINX_AV=/etc/nginx/sites-available
NGINX_EN=/etc/nginx/sites-enabled
FM_ROOT_FILE=/etc/nebula-panel/fm-root

die() { echo "$*" >&2; exit 2; }
valid_domain() { [[ "$1" =~ ^[a-zA-Z0-9]([a-zA-Z0-9.-]{0,251}[a-zA-Z0-9])?$ ]] || die "invalid domain"; }
valid_path()   { [[ "$1" =~ ^/[a-zA-Z0-9._/-]+$ && "$1" != *".."* ]] || die "invalid path"; }
valid_php()    { [[ "$1" =~ ^[0-9]+\.[0-9]+$ ]] || die "invalid php version"; }
valid_email()  { [[ -z "$1" || "$1" =~ ^[^@[:space:]]+@[^@[:space:]]+$ ]] || die "invalid email"; }
valid_user()   { [[ "$1" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]] || die "invalid user"; }
valid_group()  { [[ "$1" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]] || die "invalid group"; }

# Resolve a path and prove it is inside the installer-owned File Manager root.
fm_confined_path() {
  local requested="$1" root target
  [[ -r "$FM_ROOT_FILE" ]] || die "file manager root is not configured; re-run install.sh"
  root="$(realpath "$(head -n 1 "$FM_ROOT_FILE")" 2>/dev/null || true)"
  target="$(realpath "$requested" 2>/dev/null || true)"
  [[ -n "$root" && -n "$target" ]] || die "path not found"
  [[ "$target" == "$root" || "$target" == "$root"/* ]] || die "path is outside file manager root"
  printf '%s\n' "$target"
}

# Print "uid:gid:home" for a real interactive account; reject system users.
human_user_info() {
  local user="$1" row uid gid home
  valid_user "$user"
  row="$(getent passwd "$user" || true)"; [[ -n "$row" ]] || die "user not found"
  IFS=: read -r _ _ uid gid _ home _ <<<"$row"
  [[ "$uid" =~ ^[0-9]+$ && "$uid" -ge 1000 && "$uid" -lt 65534 ]] || die "not a human user"
  valid_path "$home"
  printf '%s:%s:%s\n' "$uid" "$gid" "$home"
}

CMD="${1:-}"; shift || true

case "$CMD" in

  # File metadata operations are confined by /etc/nebula-panel/fm-root.
  file-chmod)
    TARGET="$(fm_confined_path "${1:-}")"; MODE="${2:-}"
    [[ "$MODE" =~ ^[0-7]{3,4}$ ]] || die "invalid mode"
    chmod "$MODE" "$TARGET"
    echo "permissions updated"
    ;;

  file-chown)
    TARGET="$(fm_confined_path "${1:-}")"; OWNER="${2:-}"; GROUP="${3:-}"
    valid_user "$OWNER"; valid_group "$GROUP"
    getent passwd "$OWNER" >/dev/null || die "owner not found"
    getent group "$GROUP" >/dev/null || die "group not found"
    chown "$OWNER:$GROUP" "$TARGET"
    echo "ownership updated"
    ;;

  # ssh-keys-list <user> / ssh-key-add <user> <base64-key> / ssh-key-delete <user> <line>
  ssh-keys-list)
    USER_NAME="${1:-}"; INFO="$(human_user_info "$USER_NAME")"; HOME_DIR="${INFO#*:*:}"
    KEY_FILE="$HOME_DIR/.ssh/authorized_keys"
    [[ -f "$KEY_FILE" ]] || exit 0
    N=0
    while IFS= read -r KEY_LINE || [[ -n "$KEY_LINE" ]]; do
      [[ -z "$KEY_LINE" || "$KEY_LINE" == \#* ]] && continue
      N=$((N + 1))
      META="$(printf '%s\n' "$KEY_LINE" | ssh-keygen -lf - 2>/dev/null || true)"
      [[ -n "$META" ]] && printf '%s\t%s\n' "$N" "$META"
    done < "$KEY_FILE"
    ;;

  ssh-key-add)
    USER_NAME="${1:-}"; KEY_B64="${2:-}"; INFO="$(human_user_info "$USER_NAME")"
    UID_NUM="${INFO%%:*}"; REST="${INFO#*:}"; GID_NUM="${REST%%:*}"; HOME_DIR="${INFO#*:*:}"
    [[ "$KEY_B64" =~ ^[A-Za-z0-9+/=]+$ ]] || die "invalid key encoding"
    KEY_LINE="$(printf '%s' "$KEY_B64" | base64 -d 2>/dev/null || true)"
    [[ "$KEY_LINE" != *$'\n'* && "$KEY_LINE" =~ ^(ssh-ed25519|ssh-rsa|ecdsa-sha2-nistp(256|384|521))[[:space:]]+[A-Za-z0-9+/=]+([[:space:]].*)?$ ]] || die "invalid public key"
    printf '%s\n' "$KEY_LINE" | ssh-keygen -lf - >/dev/null 2>&1 || die "invalid public key"
    install -d -m 0700 -o "$UID_NUM" -g "$GID_NUM" "$HOME_DIR/.ssh"
    KEY_FILE="$HOME_DIR/.ssh/authorized_keys"
    touch "$KEY_FILE"; chown "$UID_NUM:$GID_NUM" "$KEY_FILE"; chmod 0600 "$KEY_FILE"
    grep -Fqx -- "$KEY_LINE" "$KEY_FILE" || printf '%s\n' "$KEY_LINE" >> "$KEY_FILE"
    echo "key added for $USER_NAME"
    ;;

  ssh-key-delete)
    USER_NAME="${1:-}"; KEY_NUM="${2:-}"; INFO="$(human_user_info "$USER_NAME")"
    UID_NUM="${INFO%%:*}"; REST="${INFO#*:}"; GID_NUM="${REST%%:*}"; HOME_DIR="${INFO#*:*:}"
    [[ "$KEY_NUM" =~ ^[1-9][0-9]*$ ]] || die "invalid key number"
    KEY_FILE="$HOME_DIR/.ssh/authorized_keys"; [[ -f "$KEY_FILE" ]] || die "key file not found"
    TMP="$(mktemp)"; trap 'rm -f "$TMP"' EXIT
    awk -v wanted="$KEY_NUM" 'BEGIN{n=0} /^[[:space:]]*($|#)/{print;next} {n++; if(n!=wanted) print}' "$KEY_FILE" > "$TMP"
    install -m 0600 -o "$UID_NUM" -g "$GID_NUM" "$TMP" "$KEY_FILE"
    echo "key removed for $USER_NAME"
    ;;

  # List installed PHP-FPM versions (one per line, e.g. 8.1).
  php-versions)
    ls /run/php/ 2>/dev/null | grep -oE 'php[0-9.]+-fpm\.sock' \
      | sed -E 's/php([0-9.]+)-fpm\.sock/\1/' | sort -uV
    ;;

  # site-create <domain> <docroot> <phpversion>
  site-create)
    DOMAIN="${1:-}"; DOCROOT="${2:-}"; PHPVER="${3:-}"
    valid_domain "$DOMAIN"; valid_path "$DOCROOT"; valid_php "$PHPVER"
    SOCK="/run/php/php${PHPVER}-fpm.sock"
    [[ -S "$SOCK" ]] || die "PHP-FPM $PHPVER not installed ($SOCK missing)"
    [[ -e "$NGINX_AV/$DOMAIN" ]] && die "site already exists"
    mkdir -p "$DOCROOT"
    if [[ -z "$(ls -A "$DOCROOT" 2>/dev/null)" ]]; then
      printf '<!doctype html><html><body style="font-family:sans-serif"><h1>%s</h1><p>Provisioned by Nebula Panel. PHP %s.</p></body></html>\n' \
        "$DOMAIN" "$PHPVER" > "$DOCROOT/index.html"
    fi
    chown -R www-data:www-data "$DOCROOT"
    cat > "$NGINX_AV/$DOMAIN" <<EOF
server {
    listen 80;
    listen [::]:80;
    # Only configure the hostname the user entered. In particular, a site such
    # as app.example.com must not silently gain www.app.example.com.
    server_name $DOMAIN;
    root $DOCROOT;
    index index.php index.html index.htm;
    access_log /var/log/nginx/${DOMAIN}.access.log;
    error_log  /var/log/nginx/${DOMAIN}.error.log;
    location / { try_files \$uri \$uri/ /index.php\$is_args\$args; }
    location ~ \.php\$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:$SOCK;
    }
    location ~ /\.(?!well-known).* { deny all; }
}
EOF
    ln -sf "$NGINX_AV/$DOMAIN" "$NGINX_EN/$DOMAIN"
    nginx -t || { rm -f "$NGINX_EN/$DOMAIN" "$NGINX_AV/$DOMAIN"; die "nginx config test failed"; }
    systemctl reload nginx
    echo "created $DOMAIN -> $DOCROOT (PHP $PHPVER)"
    ;;

  # site-delete <domain> [purge] [docroot]
  site-delete)
    DOMAIN="${1:-}"; PURGE="${2:-no}"; DOCROOT="${3:-}"
    valid_domain "$DOMAIN"
    rm -f "$NGINX_EN/$DOMAIN" "$NGINX_AV/$DOMAIN"
    nginx -t && systemctl reload nginx || true
    if [[ "$PURGE" == "purge" && -n "$DOCROOT" ]]; then
      valid_path "$DOCROOT"
      [[ "$DOCROOT" == "/" || "$DOCROOT" == "/var/www" || "$DOCROOT" == "/etc" ]] && die "refusing to delete $DOCROOT"
      rm -rf "$DOCROOT"
    fi
    echo "deleted $DOMAIN"
    ;;

  # site-ssl <domain> [email]
  site-ssl)
    DOMAIN="${1:-}"; EMAIL="${2:-}"
    valid_domain "$DOMAIN"; valid_email "$EMAIL"
    command -v certbot >/dev/null || die "certbot not installed"
    if [[ -n "$EMAIL" ]]; then
      certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos -m "$EMAIL" --redirect
    else
      certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos --register-unsafely-without-email --redirect
    fi
    echo "ssl issued for $DOMAIN"
    ;;

  # php-install <version>  (adds ondrej/php PPA on Ubuntu, installs php<ver>-fpm + common extensions)
  php-install)
    VER="${1:-}"
    [[ "$VER" =~ ^[0-9]+\.[0-9]+$ ]] || die "invalid php version"
    export DEBIAN_FRONTEND=noninteractive
    if ! command -v add-apt-repository >/dev/null 2>&1; then
        apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 update
        apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 install -y software-properties-common
    fi
    if ! grep -rqs 'ondrej/php' /etc/apt/sources.list.d 2>/dev/null; then
      add-apt-repository -y ppa:ondrej/php
    fi
      apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 update
      apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 install -y "php${VER}-fpm" "php${VER}-cli" "php${VER}-mysql" "php${VER}-curl" \
      "php${VER}-mbstring" "php${VER}-xml" "php${VER}-gd" "php${VER}-zip" \
      || die "apt install failed for php ${VER}"
    systemctl enable --now "php${VER}-fpm" || true
    echo "installed php ${VER}"
    ;;

  # pma-install <targetdir>
  pma-install)
    TARGET="${1:-}"
    valid_path "$TARGET"
    command -v curl >/dev/null || die "curl not installed"
    TMP="$(mktemp -d)"
    trap 'rm -rf "$TMP"' EXIT
      curl -fL --show-error --progress-bar -o "$TMP/pma.tar.gz" \
      "https://www.phpmyadmin.net/downloads/phpMyAdmin-latest-all-languages.tar.gz" || die "download failed"
    tar -xzf "$TMP/pma.tar.gz" -C "$TMP" || die "extract failed"
    SRC="$(find "$TMP" -maxdepth 1 -type d -name 'phpMyAdmin-*' | head -1)"
    [[ -n "$SRC" ]] || die "archive layout unexpected"
    mkdir -p "$TARGET"
    cp -a "$SRC"/. "$TARGET"/
    # Avoid an infinite producer piped into head: with pipefail, head closing
    # the pipe makes tr exit on SIGPIPE and aborts an otherwise good install.
    SECRET="$(od -An -N32 -tx1 /dev/urandom | tr -d ' \n')"
    sed "s|\$cfg\['blowfish_secret'\] = '';|\$cfg['blowfish_secret'] = '${SECRET}';|" \
      "$TARGET/config.sample.inc.php" > "$TARGET/config.inc.php"
    mkdir -p "$TARGET/tmp"
    chown -R www-data:www-data "$TARGET"
    chmod 700 "$TARGET/tmp"
    echo "phpMyAdmin installed at $TARGET"
    ;;

  # pma-remove <targetdir>
  pma-remove)
    TARGET="${1:-}"
    valid_path "$TARGET"
    [[ "$TARGET" == "/" || "$TARGET" == "/var/www" ]] && die "refusing"
    [[ -f "$TARGET/config.inc.php" ]] || die "not a phpMyAdmin dir"
    rm -rf "$TARGET"
    echo "removed $TARGET"
    ;;

  # cert-list  -> raw `certbot certificates` output (parsed by the panel)
  cert-list)
    command -v certbot >/dev/null || die "certbot not installed"
    certbot certificates 2>/dev/null
    ;;

  # cert-renew [name]  -> renew all, or one certificate by name
  cert-renew)
    NAME="${1:-}"
    command -v certbot >/dev/null || die "certbot not installed"
    if [[ -n "$NAME" ]]; then
      valid_domain "$NAME"
      certbot renew --cert-name "$NAME" --non-interactive
    else
      certbot renew --non-interactive
    fi
    echo "renew complete"
    ;;

  # cert-delete <name>
  cert-delete)
    NAME="${1:-}"; valid_domain "$NAME"
    command -v certbot >/dev/null || die "certbot not installed"
    certbot delete --cert-name "$NAME" --non-interactive
    echo "deleted $NAME"
    ;;

  # php-ini <version> <key> <value>  (whitelisted keys; sets fpm+cli, reloads fpm)
  php-ini)
    VER="${1:-}"; KEY="${2:-}"; VAL="${3:-}"
    valid_php "$VER"
    case "$KEY" in
      memory_limit|upload_max_filesize|post_max_size|max_execution_time|max_input_time|max_input_vars|display_errors) ;;
      *) die "ini key not allowed" ;;
    esac
    [[ "$VAL" =~ ^[A-Za-z0-9_.]+$ ]] || die "invalid value"
    changed=0
    for SAPI in fpm cli; do
      INI="/etc/php/${VER}/${SAPI}/php.ini"
      [[ -f "$INI" ]] || continue
      if grep -qE "^;?[[:space:]]*${KEY}[[:space:]]*=" "$INI"; then
        sed -i -E "s|^;?[[:space:]]*(${KEY})[[:space:]]*=.*|\1 = ${VAL}|" "$INI"
      else
        echo "${KEY} = ${VAL}" >> "$INI"
      fi
      changed=1
    done
    [[ "$changed" == 1 ]] || die "no php.ini found for ${VER}"
    systemctl reload "php${VER}-fpm" 2>/dev/null || systemctl restart "php${VER}-fpm" 2>/dev/null || true
    echo "set ${KEY}=${VAL} for php ${VER}"
    ;;

  *)
    die "unknown command: $CMD"
    ;;
esac
