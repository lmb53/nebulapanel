#!/usr/bin/env bash
#
# nebula-helper — the ONLY privileged surface of Nebula Panel.
# Installed root-owned to /usr/local/bin/nebula-helper with a single sudoers
# rule (www-data ALL=(root) NOPASSWD: /usr/local/bin/nebula-helper *).
#
# It performs a fixed, validated set of operations so the panel never needs a
# broad `tee`/`ln`/`mkdir`/`certbot` sudo grant. Every argument is validated
# here before use. Keep this file root-owned and NOT writable by the web user.
#
set -euo pipefail

NGINX_AV=/etc/nginx/sites-available
NGINX_EN=/etc/nginx/sites-enabled
FM_ROOT_FILE=/etc/nebula-panel/fm-root
PANEL_ROOT_FILE=/etc/nebula-panel/panel-root
BIND_ZONE_DIR=/etc/bind/nebula-zones
BIND_ZONE_CONF=/etc/bind/nebula-zones.conf
MAIL_DIR=/etc/nebula-mail
MAIL_STORE=/var/mail/nebula
MAIL_VUID=5000
MAIL_VGID=5000
DKIM_DIR="$MAIL_DIR/dkim"

die() { echo "$*" >&2; exit 2; }
valid_domain() { [[ "$1" =~ ^[a-zA-Z0-9]([a-zA-Z0-9.-]{0,251}[a-zA-Z0-9])?$ ]] || die "invalid domain"; }
valid_path()   { [[ "$1" =~ ^/[a-zA-Z0-9._/-]+$ && "$1" != *".."* ]] || die "invalid path"; }
valid_php()    { [[ "$1" =~ ^[0-9]+\.[0-9]+$ ]] || die "invalid php version"; }
valid_email()  { [[ -z "$1" || "$1" =~ ^[^@[:space:]]+@[^@[:space:]]+$ ]] || die "invalid email"; }
valid_user()   { [[ "$1" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]] || die "invalid user"; }
valid_group()  { [[ "$1" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]] || die "invalid group"; }

# Schedule PHP-FPM work after the current panel FastCGI response can finish.
schedule_php_service() {
  local action="$1" ver="$2" unit
  [[ "$action" == "reload" || "$action" == "restart" ]] || die "invalid PHP service action"
  valid_php "$ver"
  unit="nebula-php${ver//./-}-${action}-$(date +%s)-$$-$RANDOM"
  if command -v systemd-run >/dev/null 2>&1; then
    systemd-run --quiet --unit="$unit" --on-active=2s /bin/sh -c \
      "systemctl ${action} php${ver}-fpm 2>/dev/null || systemctl restart php${ver}-fpm 2>/dev/null || true" || true
  else
    nohup /bin/sh -c "sleep 2; systemctl ${action} php${ver}-fpm 2>/dev/null || systemctl restart php${ver}-fpm 2>/dev/null || true" \
      >/dev/null 2>&1 &
  fi
}

# Resolve a path and prove it is inside the installer-owned File Manager root.
fm_confined_path() {
  local requested="$1" root target panel_root
  [[ -r "$FM_ROOT_FILE" ]] || die "file manager root is not configured; re-run install.sh"
  root="$(realpath "$(head -n 1 "$FM_ROOT_FILE")" 2>/dev/null || true)"
  target="$(realpath "$requested" 2>/dev/null || true)"
  [[ -n "$root" && -n "$target" ]] || die "path not found"
  [[ "$target" == "$root" || "$target" == "$root"/* ]] || die "path is outside file manager root"
  panel_root="$(realpath "$(head -n 1 "$PANEL_ROOT_FILE" 2>/dev/null)" 2>/dev/null || true)"
  [[ -z "$panel_root" || ( "$target" != "$panel_root" && "$target" != "$panel_root"/* ) ]] || die "panel-private path is not allowed"
  printf '%s\n' "$target"
}

# Resolve a not-yet-created path by validating its existing parent.
fm_confined_new_path() {
  local requested="$1" root parent target panel_root
  [[ -r "$FM_ROOT_FILE" ]] || die "file manager root is not configured; re-run install.sh"
  root="$(realpath "$(head -n 1 "$FM_ROOT_FILE")" 2>/dev/null || true)"
  parent="$(realpath "$(dirname "$requested")" 2>/dev/null || true)"
  [[ -n "$root" && -n "$parent" ]] || die "destination parent not found"
  [[ "$parent" == "$root" || "$parent" == "$root"/* ]] || die "destination is outside file manager root"
  target="$parent/$(basename "$requested")"
  panel_root="$(realpath "$(head -n 1 "$PANEL_ROOT_FILE" 2>/dev/null)" 2>/dev/null || true)"
  [[ -z "$panel_root" || ( "$target" != "$panel_root" && "$target" != "$panel_root"/* ) ]] || die "panel-private destination is not allowed"
  [[ ! -e "$target" ]] || die "destination already exists"
  printf '%s\n' "$target"
}

# Print "uid:gid:home" for a real interactive account; reject system users.
human_user_info() {
  local user="$1" row uid gid home
  valid_user "$user"
  row="$(getent passwd "$user" || true)"; [[ -n "$row" ]] || die "user not found"
  IFS=: read -r _ _ uid gid _ home _ <<<"$row"
  [[ "$uid" =~ ^[0-9]+$ && "$uid" -ge 1000 && "$uid" -lt 65534 ]] || die "not a human user"
  valid_path "$home"
  printf '%s:%s:%s\n' "$uid" "$gid" "$home"
}

CMD="${1:-}"; shift || true

case "$CMD" in

  # panel-update <staged-panel-source>
  # Source must be staged by Nebula beneath its private data/_update folder.
  panel-update)
    SOURCE="${1:-}"
    [[ -r "$PANEL_ROOT_FILE" ]] || die "panel root is not configured; re-run install.sh"
    PANEL_ROOT="$(realpath "$(head -n 1 "$PANEL_ROOT_FILE")")"
    SOURCE="$(realpath "$SOURCE" 2>/dev/null || true)"
    [[ -n "$PANEL_ROOT" && -n "$SOURCE" ]] || die "update source not found"
    [[ "$SOURCE" == "$PANEL_ROOT/data/_update/"* ]] || die "update source is outside the staging directory"
    [[ -f "$SOURCE/index.php" && -f "$SOURCE/lib/bootstrap.php" ]] || die "invalid panel update source"
    command -v rsync >/dev/null || die "rsync is required"
    SNAP_DIR="$PANEL_ROOT/data/backups"; mkdir -p "$SNAP_DIR"
    SNAP="$SNAP_DIR/pre-update-$(date +%Y%m%d-%H%M%S).tar.gz"
    tar -czf "$SNAP" --exclude='data/backups' --exclude='data/_update' -C "$(dirname "$PANEL_ROOT")" "$(basename "$PANEL_ROOT")"
    chown www-data:www-data "$SNAP"; chmod 0600 "$SNAP"
    rsync -a --delete --exclude=data --exclude=config.php "$SOURCE/" "$PANEL_ROOT/"
    chown -R root:root "$PANEL_ROOT"
    find "$PANEL_ROOT" -type d -exec chmod 0755 {} +
    find "$PANEL_ROOT" -type f -exec chmod 0644 {} +
    chown -R www-data:www-data "$PANEL_ROOT/data"
    chmod 0700 "$PANEL_ROOT/data"
    echo "snapshot=$(basename "$SNAP")"
    ;;

  # dns-zone-put <domain> <base64-zone-file>
  dns-zone-put)
    DOMAIN="${1:-}"; ZONE_B64="${2:-}"; valid_domain "$DOMAIN"
    [[ "$ZONE_B64" =~ ^[A-Za-z0-9+/=]+$ ]] || die "invalid zone encoding"
    command -v named-checkzone >/dev/null || die "BIND 9 is not installed; re-run install.sh"
    TMP="$(mktemp)"; trap 'rm -f "$TMP"' EXIT
    printf '%s' "$ZONE_B64" | base64 -d > "$TMP" 2>/dev/null || die "invalid zone data"
    named-checkzone "$DOMAIN" "$TMP" >/dev/null || die "BIND rejected the zone"
    install -d -m 0755 -o root -g bind "$BIND_ZONE_DIR"
    install -m 0644 -o root -g bind "$TMP" "$BIND_ZONE_DIR/db.$DOMAIN"
    touch "$BIND_ZONE_CONF"; chown root:bind "$BIND_ZONE_CONF"; chmod 0644 "$BIND_ZONE_CONF"
    if ! grep -qF "zone \"$DOMAIN\"" "$BIND_ZONE_CONF"; then
      printf 'zone "%s" {\n  type primary;\n  file "%s/db.%s";\n};\n' "$DOMAIN" "$BIND_ZONE_DIR" "$DOMAIN" >> "$BIND_ZONE_CONF"
    fi
    if ! grep -qF 'include "/etc/bind/nebula-zones.conf";' /etc/bind/named.conf.local; then
      printf '\ninclude "/etc/bind/nebula-zones.conf";\n' >> /etc/bind/named.conf.local
    fi
    named-checkconf >/dev/null || die "BIND configuration validation failed"
    systemctl reload bind9 2>/dev/null || systemctl restart bind9
    echo "published authoritative zone $DOMAIN"
    ;;

  dns-zone-delete)
    DOMAIN="${1:-}"; valid_domain "$DOMAIN"
    if [[ -f "$BIND_ZONE_CONF" ]]; then
      TMP="$(mktemp)"; trap 'rm -f "$TMP"' EXIT
      awk -v target="zone \"$DOMAIN\"" '
        index($0,target)==1 { skip=1 }
        skip && /^};[[:space:]]*$/ { skip=0; next }
        !skip { print }
      ' "$BIND_ZONE_CONF" > "$TMP"
      install -m 0644 -o root -g bind "$TMP" "$BIND_ZONE_CONF"
    fi
    rm -f "$BIND_ZONE_DIR/db.$DOMAIN"
    named-checkconf >/dev/null || die "BIND configuration validation failed"
    systemctl reload bind9 2>/dev/null || systemctl restart bind9
    echo "removed authoritative zone $DOMAIN"
    ;;

  # File metadata operations are confined by /etc/nebula-panel/fm-root.
  file-chmod)
    TARGET="$(fm_confined_path "${1:-}")"; MODE="${2:-}"
    [[ "$MODE" =~ ^[0-7]{3,4}$ ]] || die "invalid mode"
    chmod "$MODE" "$TARGET"
    echo "permissions updated"
    ;;

  file-chown)
    TARGET="$(fm_confined_path "${1:-}")"; OWNER="${2:-}"; GROUP="${3:-}"
    valid_user "$OWNER"; valid_group "$GROUP"
    getent passwd "$OWNER" >/dev/null || die "owner not found"
    getent group "$GROUP" >/dev/null || die "group not found"
    chown "$OWNER:$GROUP" "$TARGET"
    echo "ownership updated"
    ;;

  # file-delete <path>  — recursively remove a file or directory, confined to
  # the File Manager root. Runs as root so it can clear docroots whose files
  # are owned by other users (e.g. root-owned git-deployed content) and
  # non-empty directories the web user cannot remove itself.
  file-delete)
    TARGET="$(fm_confined_path "${1:-}")"
    ROOT="$(realpath "$(head -n 1 "$FM_ROOT_FILE")")"
    [[ -n "$ROOT" && "$TARGET" != "$ROOT" ]] || die "refusing to delete the file manager root"
    rm -rf -- "$TARGET"
    echo "deleted $TARGET"
    ;;

  # file-compress <zip|tar.gz> <absolute-target> <absolute-source> [...]
  # Both destination and sources are independently confined below FM_ROOT.
  file-compress)
    FORMAT="${1:-}"; shift || true
    TARGET="$(fm_confined_new_path "${1:-}")"; shift || true
    [[ "$FORMAT" == "zip" || "$FORMAT" == "tar.gz" ]] || die "unsupported archive format"
    [[ "$FORMAT" != "zip" || "$TARGET" == *.zip ]] || die "zip target must end in .zip"
    [[ "$FORMAT" != "tar.gz" || "$TARGET" == *.tar.gz ]] || die "tar target must end in .tar.gz"
    [[ "$#" -ge 1 && "$#" -le 100 ]] || die "select between 1 and 100 items"
    ROOT="$(realpath "$(head -n 1 "$FM_ROOT_FILE")")"
    RELS=()
    FIRST=""
    for REQUESTED in "$@"; do
      SOURCE="$(fm_confined_path "$REQUESTED")"
      [[ "$SOURCE" != "$ROOT" ]] || die "cannot archive the file manager root"
      [[ -n "$FIRST" ]] || FIRST="$SOURCE"
      RELS+=("${SOURCE#"$ROOT"/}")
    done
    if [[ "$FORMAT" == "zip" ]]; then
      command -v zip >/dev/null || die "zip is not installed; re-run install.sh"
      (cd "$ROOT" && zip -rq "$TARGET" -- "${RELS[@]}") || { rm -f "$TARGET"; die "zip creation failed"; }
    else
      tar -czf "$TARGET" -C "$ROOT" -- "${RELS[@]}" || { rm -f "$TARGET"; die "tar archive creation failed"; }
    fi
    chown --reference="$FIRST" "$TARGET" 2>/dev/null || true
    chmod 0640 "$TARGET" 2>/dev/null || true
    echo "created $TARGET"
    ;;

  # ssh-keys-list <user> / ssh-key-add <user> <base64-key> / ssh-key-delete <user> <line>
  ssh-keys-list)
    USER_NAME="${1:-}"; INFO="$(human_user_info "$USER_NAME")"; HOME_DIR="${INFO#*:*:}"
    KEY_FILE="$HOME_DIR/.ssh/authorized_keys"
    [[ -f "$KEY_FILE" ]] || exit 0
    N=0
    while IFS= read -r KEY_LINE || [[ -n "$KEY_LINE" ]]; do
      [[ -z "$KEY_LINE" || "$KEY_LINE" == \#* ]] && continue
      N=$((N + 1))
      META="$(printf '%s\n' "$KEY_LINE" | ssh-keygen -lf - 2>/dev/null || true)"
      [[ -n "$META" ]] && printf '%s\t%s\n' "$N" "$META"
    done < "$KEY_FILE"
    ;;

  ssh-key-add)
    USER_NAME="${1:-}"; KEY_B64="${2:-}"; INFO="$(human_user_info "$USER_NAME")"
    UID_NUM="${INFO%%:*}"; REST="${INFO#*:}"; GID_NUM="${REST%%:*}"; HOME_DIR="${INFO#*:*:}"
    [[ "$KEY_B64" =~ ^[A-Za-z0-9+/=]+$ ]] || die "invalid key encoding"
    KEY_LINE="$(printf '%s' "$KEY_B64" | base64 -d 2>/dev/null || true)"
    [[ "$KEY_LINE" != *$'\n'* && "$KEY_LINE" =~ ^(ssh-ed25519|ssh-rsa|ecdsa-sha2-nistp(256|384|521))[[:space:]]+[A-Za-z0-9+/=]+([[:space:]].*)?$ ]] || die "invalid public key"
    printf '%s\n' "$KEY_LINE" | ssh-keygen -lf - >/dev/null 2>&1 || die "invalid public key"
    install -d -m 0700 -o "$UID_NUM" -g "$GID_NUM" "$HOME_DIR/.ssh"
    KEY_FILE="$HOME_DIR/.ssh/authorized_keys"
    touch "$KEY_FILE"; chown "$UID_NUM:$GID_NUM" "$KEY_FILE"; chmod 0600 "$KEY_FILE"
    grep -Fqx -- "$KEY_LINE" "$KEY_FILE" || printf '%s\n' "$KEY_LINE" >> "$KEY_FILE"
    echo "key added for $USER_NAME"
    ;;

  ssh-key-delete)
    USER_NAME="${1:-}"; KEY_NUM="${2:-}"; INFO="$(human_user_info "$USER_NAME")"
    UID_NUM="${INFO%%:*}"; REST="${INFO#*:}"; GID_NUM="${REST%%:*}"; HOME_DIR="${INFO#*:*:}"
    [[ "$KEY_NUM" =~ ^[1-9][0-9]*$ ]] || die "invalid key number"
    KEY_FILE="$HOME_DIR/.ssh/authorized_keys"; [[ -f "$KEY_FILE" ]] || die "key file not found"
    TMP="$(mktemp)"; trap 'rm -f "$TMP"' EXIT
    awk -v wanted="$KEY_NUM" 'BEGIN{n=0} /^[[:space:]]*($|#)/{print;next} {n++; if(n!=wanted) print}' "$KEY_FILE" > "$TMP"
    install -m 0600 -o "$UID_NUM" -g "$GID_NUM" "$TMP" "$KEY_FILE"
    echo "key removed for $USER_NAME"
    ;;

  # List installed PHP-FPM versions (one per line, e.g. 8.1).
  php-versions)
    ls /run/php/ 2>/dev/null | grep -oE 'php[0-9.]+-fpm\.sock' \
      | sed -E 's/php([0-9.]+)-fpm\.sock/\1/' | sort -uV
    ;;

  # site-create <domain> <docroot> <phpversion>
  site-create)
    DOMAIN="${1:-}"; DOCROOT="${2:-}"; PHPVER="${3:-}"
    valid_domain "$DOMAIN"; valid_path "$DOCROOT"; valid_php "$PHPVER"
    SOCK="/run/php/php${PHPVER}-fpm.sock"
    [[ -S "$SOCK" ]] || die "PHP-FPM $PHPVER not installed ($SOCK missing)"
    [[ -e "$NGINX_AV/$DOMAIN" ]] && die "site already exists"
    mkdir -p "$DOCROOT"
    if [[ -z "$(ls -A "$DOCROOT" 2>/dev/null)" ]]; then
      printf '<!doctype html><html><body style="font-family:sans-serif"><h1>%s</h1><p>Provisioned by Nebula Panel. PHP %s.</p></body></html>\n' \
        "$DOMAIN" "$PHPVER" > "$DOCROOT/index.html"
    fi
    chown -R www-data:www-data "$DOCROOT"
    cat > "$NGINX_AV/$DOMAIN" <<EOF
server {
    listen 80;
    listen [::]:80;
    # Only configure the hostname the user entered. In particular, a site such
    # as app.example.com must not silently gain www.app.example.com.
    server_name $DOMAIN;
    root $DOCROOT;
    index index.php index.html index.htm;
    access_log /var/log/nginx/${DOMAIN}.access.log;
    error_log  /var/log/nginx/${DOMAIN}.error.log;
    location / { try_files \$uri \$uri/ /index.php\$is_args\$args; }
    location ~ \.php\$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:$SOCK;
    }
    location ~ /\.(?!well-known).* { deny all; }
}
EOF
    ln -sf "$NGINX_AV/$DOMAIN" "$NGINX_EN/$DOMAIN"
    nginx -t || { rm -f "$NGINX_EN/$DOMAIN" "$NGINX_AV/$DOMAIN"; die "nginx config test failed"; }
    systemctl reload nginx
    echo "created $DOMAIN -> $DOCROOT (PHP $PHPVER)"
    ;;

  # Discover simple per-domain Nginx vhosts managed in the same layout Nebula
  # creates. Output: domain<TAB>docroot<TAB>php-version<TAB>ssl-state.
  site-list)
    shopt -s nullglob
    for CONF in "$NGINX_AV"/*; do
      [[ -f "$CONF" ]] || continue
      DOMAIN="$(basename "$CONF")"
      [[ "$DOMAIN" == "default" || "$DOMAIN" == "nebula" ]] && continue
      [[ "$DOMAIN" =~ ^[a-zA-Z0-9]([a-zA-Z0-9.-]{0,251}[a-zA-Z0-9])?$ ]] || continue
      SERVER_NAME="$(awk '/^[[:space:]]*server_name[[:space:]]+/ {gsub(/;/, "", $2); print $2; exit}' "$CONF")"
      [[ "$SERVER_NAME" == "$DOMAIN" ]] || continue
      DOCROOT="$(awk '/^[[:space:]]*root[[:space:]]+/ {gsub(/;/, "", $2); print $2; exit}' "$CONF")"
      [[ "$DOCROOT" =~ ^/[a-zA-Z0-9._/-]+$ && "$DOCROOT" != *".."* ]] || continue
      PHPVER="$(grep -m1 -E 'fastcgi_pass[[:space:]]+unix:/run/php/php[0-9]+\.[0-9]+-fpm\.sock;' "$CONF" 2>/dev/null \
        | sed -E 's#.*fastcgi_pass[[:space:]]+unix:/run/php/php([0-9]+\.[0-9]+)-fpm\.sock;.*#\1#' || true)"
      [[ -n "$PHPVER" ]] || PHPVER=""
      SSL=no; grep -qE '^[[:space:]]*ssl_certificate[[:space:]]' "$CONF" && SSL=yes
      printf '%s\t%s\t%s\t%s\n' "$DOMAIN" "$DOCROOT" "$PHPVER" "$SSL"
    done
    ;;

  # Change the PHP-FPM socket used by an existing Nebula Nginx vhost.
  site-php)
    DOMAIN="${1:-}"; PHPVER="${2:-}"
    valid_domain "$DOMAIN"; valid_php "$PHPVER"
    CONF="$NGINX_AV/$DOMAIN"; SOCK="/run/php/php${PHPVER}-fpm.sock"
    [[ -f "$CONF" ]] || die "website config not found"
    [[ -S "$SOCK" ]] || die "PHP-FPM $PHPVER is not running"
    grep -qE 'fastcgi_pass[[:space:]]+unix:/run/php/php[0-9.]+-fpm\.sock;' "$CONF" || die "website has no managed PHP-FPM socket"
    TMP="$(mktemp)"; trap 'rm -f "$TMP"' EXIT; cp "$CONF" "$TMP"
    sed -i -E "s#fastcgi_pass[[:space:]]+unix:/run/php/php[0-9.]+-fpm\.sock;#fastcgi_pass unix:$SOCK;#" "$CONF"
    nginx -t >/dev/null 2>&1 || { cp "$TMP" "$CONF"; die "nginx config test failed"; }
    systemctl reload nginx
    echo "updated $DOMAIN to PHP $PHPVER"
    ;;

  # site-stats <docroot> -> bytes<TAB>files. Read-only but privileged so
  # sites with restrictive ownership are still measured accurately.
  site-stats)
    DOCROOT="${1:-}"; valid_path "$DOCROOT"; [[ -d "$DOCROOT" ]] || die "document root not found"
    BYTES="$(du -sb -- "$DOCROOT" 2>/dev/null | awk '{print $1}')"
    FILES="$(find "$DOCROOT" -xdev -type f 2>/dev/null | wc -l | tr -d ' ')"
    printf '%s\t%s\n' "${BYTES:-0}" "${FILES:-0}"
    ;;

  # site-delete <domain> [purge] [docroot]
  site-delete)
    DOMAIN="${1:-}"; PURGE="${2:-no}"; DOCROOT="${3:-}"
    valid_domain "$DOMAIN"
    rm -f "$NGINX_EN/$DOMAIN" "$NGINX_AV/$DOMAIN"
    nginx -t && systemctl reload nginx || true
    if [[ "$PURGE" == "purge" ]]; then
      if [[ -n "$DOCROOT" ]]; then
        valid_path "$DOCROOT"
        [[ "$DOCROOT" == "/" || "$DOCROOT" == "/var/www" || "$DOCROOT" == "/etc" ]] && die "refusing to delete $DOCROOT"
        rm -rf "$DOCROOT"
      fi
      # Remove other server-side traces of the site so nothing is left behind.
      rm -rf "/etc/nebula-panel/certs/$DOMAIN"
      rm -f "/var/log/nginx/${DOMAIN}.access.log" "/var/log/nginx/${DOMAIN}.error.log" \
            /var/log/nginx/${DOMAIN}.access.log.* /var/log/nginx/${DOMAIN}.error.log.* 2>/dev/null || true
    fi
    echo "deleted $DOMAIN"
    ;;

  # site-ssl <domain> [email]
  site-ssl)
    DOMAIN="${1:-}"; EMAIL="${2:-}"
    valid_domain "$DOMAIN"; valid_email "$EMAIL"
    command -v certbot >/dev/null || die "certbot not installed"
    if [[ -n "$EMAIL" ]]; then
      certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos -m "$EMAIL" --redirect
    else
      certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos --register-unsafely-without-email --redirect
    fi
    echo "ssl issued for $DOMAIN"
    ;;

  # php-install <version>  (adds ondrej/php PPA on Ubuntu, installs php<ver>-fpm + common extensions)
  php-install)
    VER="${1:-}"
    case "$VER" in 8.2|8.3|8.4|8.5) ;; *) die "unsupported php version" ;; esac
    export DEBIAN_FRONTEND=noninteractive
    if ! command -v add-apt-repository >/dev/null 2>&1; then
        apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 update
        apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 install -y software-properties-common
    fi
    if ! grep -rqs 'ondrej/php' /etc/apt/sources.list.d 2>/dev/null; then
      add-apt-repository -y ppa:ondrej/php
    fi
    # Stop the ondrej/php PPA from hijacking the system-default (unversioned)
    # php meta-packages. The base install ships `php-fpm`, `php-cli`, … which
    # track "the default PHP version"; once this PPA is added that default
    # becomes ondrej's newest *stable* (e.g. 8.4). Without this pin, asking for
    # 8.5 also drags in 8.4 through those metas, and the updater then perpetually
    # tries to pull/keep-back a second PHP. Pinning the ondrej candidate for the
    # unversioned metas to -1 leaves them on the distro's version, while the
    # explicitly versioned "php8.5-*" packages below still come from the PPA.
    PIN=/etc/apt/preferences.d/nebula-ondrej-php
    cat > "$PIN" <<'PINEOF'
# Managed by Nebula Panel. Keeps unversioned php meta-packages on the distro
# default so adding extra PHP versions never pulls in another one.
Package: php php-fpm php-cli php-mysql php-curl php-mbstring php-xml php-zip php-gd php-bcmath php-intl php-soap php-imap php-json php-opcache php-dev php-pear php-readline php-redis php-imagick php-xdebug php-memcached php-apcu
Pin: release o=LP-PPA-ondrej-php
Pin-Priority: -1
PINEOF
    chmod 0644 "$PIN"
      apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 update
      apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 install -y "php${VER}-fpm" "php${VER}-cli" "php${VER}-mysql" "php${VER}-curl" \
      "php${VER}-mbstring" "php${VER}-xml" "php${VER}-gd" "php${VER}-zip" \
      || die "apt install failed for php ${VER}"
    systemctl enable --now "php${VER}-fpm" || true
    echo "installed php ${VER}"
    ;;

  # php-extension <install|enable|disable> <version> <extension>
  php-extension)
    ACTION="${1:-}"; VER="${2:-}"; EXTENSION="${3:-}"
    valid_php "$VER"
    case "$ACTION" in install|enable|disable) ;; *) die "invalid extension action" ;; esac
    case "$EXTENSION" in curl|mbstring|xml|gd|zip|mysql|intl|bcmath|soap|imagick|redis|xdebug|imap|opcache) ;;
      *) die "extension is not managed" ;;
    esac
    PACKAGE="php${VER}-${EXTENSION}"
    if [[ "$ACTION" == "install" ]]; then
      export DEBIAN_FRONTEND=noninteractive
      apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 update
      apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 install -y "$PACKAGE" || die "extension install failed"
    else
      MODULES=("$EXTENSION")
      case "$EXTENSION" in
        mysql) MODULES=(mysqlnd mysqli pdo_mysql) ;;
        xml) MODULES=(dom simplexml xml xmlreader xmlwriter xsl) ;;
      esac
      for MODULE in "${MODULES[@]}"; do
        [[ -f "/etc/php/$VER/mods-available/$MODULE.ini" ]] || continue
        if [[ "$ACTION" == "enable" ]]; then phpenmod -v "$VER" -s ALL "$MODULE"
        else phpdismod -v "$VER" -s ALL "$MODULE"; fi
      done
    fi
    schedule_php_service reload "$VER"
    echo "$ACTION complete for PHP $VER $EXTENSION"
    ;;

  # Restart one or every running PHP-FPM version without dropping this request.
  php-restart)
    VER="${1:-}"
    if [[ "$VER" == "all" ]]; then
      FOUND=0
      for SOCK in /run/php/php*-fpm.sock; do
        [[ -S "$SOCK" ]] || continue
        ITEM="$(basename "$SOCK" | sed -E 's/php([0-9.]+)-fpm\.sock/\1/')"
        valid_php "$ITEM"; schedule_php_service restart "$ITEM"; FOUND=1
      done
      [[ "$FOUND" == 1 ]] || die "no running PHP-FPM pools found"
    else
      valid_php "$VER"; schedule_php_service restart "$VER"
    fi
    echo "PHP-FPM restart scheduled"
    ;;

  # Replace/restore the FPM php.ini after decoding and validating a bounded
  # payload. A single previous version is retained for the Revert action.
  php-ini-replace)
    VER="${1:-}"; INI_B64="${2:-}"; valid_php "$VER"
    [[ "$INI_B64" =~ ^[A-Za-z0-9+/=]+$ && "${#INI_B64}" -le 500000 ]] || die "invalid or oversized php.ini payload"
    INI="/etc/php/$VER/fpm/php.ini"; [[ -f "$INI" ]] || die "FPM php.ini not found"
    TMP="$(mktemp)"; trap 'rm -f "$TMP"' EXIT
    printf '%s' "$INI_B64" | base64 -d > "$TMP" 2>/dev/null || die "invalid php.ini encoding"
    [[ -s "$TMP" && "$(wc -c < "$TMP")" -le 350000 ]] || die "php.ini is empty or too large"
    CHECK="$("php$VER" -c "$TMP" -r 'exit(0);' 2>&1)" || die "php.ini validation failed: $CHECK"
    [[ "$CHECK" != *"syntax error"* ]] || die "php.ini validation failed: $CHECK"
    cp "$INI" "$INI.nebula-backup"
    chown --reference="$INI" "$INI.nebula-backup" 2>/dev/null || true
    chmod --reference="$INI" "$INI.nebula-backup" 2>/dev/null || true
    install -m 0644 -o root -g root "$TMP" "$INI"
    schedule_php_service reload "$VER"
    echo "php.ini saved; reload scheduled"
    ;;

  php-ini-restore)
    VER="${1:-}"; valid_php "$VER"
    INI="/etc/php/$VER/fpm/php.ini"; BACKUP="$INI.nebula-backup"
    [[ -f "$INI" && -f "$BACKUP" ]] || die "no php.ini backup is available"
    TMP="$(mktemp)"; trap 'rm -f "$TMP"' EXIT; cp "$INI" "$TMP"
    install -m 0644 -o root -g root "$BACKUP" "$INI"
    install -m 0644 -o root -g root "$TMP" "$BACKUP"
    schedule_php_service reload "$VER"
    echo "php.ini restored; reload scheduled"
    ;;

  composer-install)
    command -v composer >/dev/null 2>&1 && die "Composer is already installed"
    export DEBIAN_FRONTEND=noninteractive
    apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 update
    apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 install -y composer || die "Composer installation failed"
    echo "Composer installed"
    ;;

  # pma-install <targetdir>
  pma-install)
    TARGET="${1:-}"
    valid_path "$TARGET"
    command -v curl >/dev/null || die "curl not installed"
    TMP="$(mktemp -d)"
    trap 'rm -rf "$TMP"' EXIT
      curl -fL --show-error --progress-bar -o "$TMP/pma.tar.gz" \
      "https://www.phpmyadmin.net/downloads/phpMyAdmin-latest-all-languages.tar.gz" || die "download failed"
    tar -xzf "$TMP/pma.tar.gz" -C "$TMP" || die "extract failed"
    SRC="$(find "$TMP" -maxdepth 1 -type d -name 'phpMyAdmin-*' | head -1)"
    [[ -n "$SRC" ]] || die "archive layout unexpected"
    mkdir -p "$TARGET"
    cp -a "$SRC"/. "$TARGET"/
    # Avoid an infinite producer piped into head: with pipefail, head closing
    # the pipe makes tr exit on SIGPIPE and aborts an otherwise good install.
    SECRET="$(od -An -N32 -tx1 /dev/urandom | tr -d ' \n')"
    sed "s|\$cfg\['blowfish_secret'\] = '';|\$cfg['blowfish_secret'] = '${SECRET}';|" \
      "$TARGET/config.sample.inc.php" > "$TARGET/config.inc.php"
    mkdir -p "$TARGET/tmp"
    chown -R www-data:www-data "$TARGET"
    chmod 700 "$TARGET/tmp"
    echo "phpMyAdmin installed at $TARGET"
    ;;

  # pma-remove <targetdir>
  pma-remove)
    TARGET="${1:-}"
    valid_path "$TARGET"
    [[ "$TARGET" == "/" || "$TARGET" == "/var/www" ]] && die "refusing"
    [[ -f "$TARGET/config.inc.php" ]] || die "not a phpMyAdmin dir"
    rm -rf "$TARGET"
    echo "removed $TARGET"
    ;;

  # Configure phpMyAdmin's documented signon authentication mode. The panel
  # creates the short-lived signed launch URL and writes credentials only to a
  # dedicated server-side PHP session; no database password appears in a URL.
  pma-signon)
    TARGET="${1:-}"; SIGNON_URL="${2:-}"
    valid_path "$TARGET"
    [[ "$SIGNON_URL" =~ ^https?://[A-Za-z0-9._:/?=%-]+$ ]] || die "invalid signon URL"
    LOGOUT_URL="${SIGNON_URL/pma-signon/databases}"
    COOKIE_SECURE=false; [[ "$SIGNON_URL" == https://* ]] && COOKIE_SECURE=true
    CONFIG="$TARGET/config.inc.php"
    [[ -f "$CONFIG" ]] || die "phpMyAdmin config not found"
    if ! grep -q 'NEBULA_SIGNON' "$CONFIG"; then
      cat >> "$CONFIG" <<EOF

/* NEBULA_SIGNON: managed by Nebula Panel */
\$cfg['Servers'][\$i]['auth_type'] = 'signon';
\$cfg['Servers'][\$i]['SignonSession'] = 'NebulaPmaSignon';
\$cfg['Servers'][\$i]['SignonCookieParams'] = ['lifetime' => 0, 'path' => '/', 'domain' => '', 'secure' => $COOKIE_SECURE, 'httponly' => true, 'samesite' => 'Lax'];
\$cfg['Servers'][\$i]['SignonURL'] = '$SIGNON_URL';
\$cfg['Servers'][\$i]['LogoutURL'] = '$LOGOUT_URL';
EOF
    fi
    echo "phpMyAdmin signon enabled"
    ;;

  # cert-list  -> raw `certbot certificates` output (parsed by the panel)
  cert-list)
    command -v certbot >/dev/null || die "certbot not installed"
    certbot certificates 2>/dev/null
    ;;

  # cert-renew [name]  -> renew all, or one certificate by name
  cert-renew)
    NAME="${1:-}"
    command -v certbot >/dev/null || die "certbot not installed"
    if [[ -n "$NAME" ]]; then
      valid_domain "$NAME"
      certbot renew --cert-name "$NAME" --non-interactive
    else
      certbot renew --non-interactive
    fi
    echo "renew complete"
    ;;

  # cert-delete <name>
  cert-delete)
    NAME="${1:-}"; valid_domain "$NAME"
    command -v certbot >/dev/null || die "certbot not installed"
    certbot delete --cert-name "$NAME" --non-interactive
    echo "deleted $NAME"
    ;;

  # cert-upload <domain> <cert-b64> <key-b64> [chain-b64]
  cert-upload)
    DOMAIN="${1:-}"; CERT_B64="${2:-}"; KEY_B64="${3:-}"; CHAIN_B64="${4:-}"
    valid_domain "$DOMAIN"
    [[ "$CERT_B64" =~ ^[A-Za-z0-9+/=]+$ && "$KEY_B64" =~ ^[A-Za-z0-9+/=]+$ ]] || die "invalid certificate encoding"
    [[ -z "$CHAIN_B64" || "$CHAIN_B64" =~ ^[A-Za-z0-9+/=]+$ ]] || die "invalid chain encoding"
    CONF="$NGINX_AV/$DOMAIN"; [[ -f "$CONF" ]] || die "website nginx config not found"
    if grep -qE '^[[:space:]]*ssl_certificate[[:space:]]' "$CONF" && ! grep -q 'NEBULA_CUSTOM_SSL_BEGIN' "$CONF"; then
      die "the website already has a non-Nebula certificate; remove it before uploading a replacement"
    fi
    TMP="$(mktemp -d)"; trap 'rm -rf "$TMP"' EXIT
    printf '%s' "$CERT_B64" | base64 -d > "$TMP/cert.pem" 2>/dev/null || die "invalid certificate data"
    printf '%s' "$KEY_B64" | base64 -d > "$TMP/key.pem" 2>/dev/null || die "invalid private key data"
    openssl x509 -in "$TMP/cert.pem" -noout >/dev/null 2>&1 || die "invalid X.509 certificate"
    openssl x509 -in "$TMP/cert.pem" -checkhost "$DOMAIN" -noout >/dev/null 2>&1 || die "certificate does not cover $DOMAIN"
    openssl pkey -in "$TMP/key.pem" -noout >/dev/null 2>&1 || die "invalid private key"
    CERT_PUB="$(openssl x509 -in "$TMP/cert.pem" -pubkey -noout | openssl sha256)"
    KEY_PUB="$(openssl pkey -in "$TMP/key.pem" -pubout | openssl sha256)"
    [[ "$CERT_PUB" == "$KEY_PUB" ]] || die "certificate and private key do not match"
    CERT_DIR="/etc/nebula-panel/certs/$DOMAIN"
    [[ -f "$CERT_DIR/fullchain.pem" ]] && cp "$CERT_DIR/fullchain.pem" "$TMP/old-fullchain.pem"
    [[ -f "$CERT_DIR/privkey.pem" ]] && cp "$CERT_DIR/privkey.pem" "$TMP/old-privkey.pem"
    install -d -m 0700 -o root -g root "$CERT_DIR"
    cp "$TMP/cert.pem" "$TMP/fullchain.pem"
    if [[ -n "$CHAIN_B64" ]]; then
      printf '%s' "$CHAIN_B64" | base64 -d > "$TMP/chain.pem" 2>/dev/null || die "invalid chain data"
      grep -q -- '-----BEGIN CERTIFICATE-----' "$TMP/chain.pem" || die "invalid certificate chain"
      printf '\n' >> "$TMP/fullchain.pem"; cat "$TMP/chain.pem" >> "$TMP/fullchain.pem"
    fi
    install -m 0644 -o root -g root "$TMP/fullchain.pem" "$CERT_DIR/fullchain.pem"
    install -m 0600 -o root -g root "$TMP/key.pem" "$CERT_DIR/privkey.pem"
    cp "$CONF" "$TMP/nginx.conf"
    sed -i '/# NEBULA_CUSTOM_SSL_BEGIN/,/# NEBULA_CUSTOM_SSL_END/d' "$CONF"
    awk -v cert="$CERT_DIR/fullchain.pem" -v key="$CERT_DIR/privkey.pem" '
      { print }
      !done && /^[[:space:]]*server[[:space:]]*\{/ {
        print "    # NEBULA_CUSTOM_SSL_BEGIN"
        print "    listen 443 ssl;"
        print "    listen [::]:443 ssl;"
        print "    ssl_certificate " cert ";"
        print "    ssl_certificate_key " key ";"
        print "    # NEBULA_CUSTOM_SSL_END"
        done=1
      }
    ' "$CONF" > "$TMP/new.conf"
    install -m 0644 -o root -g root "$TMP/new.conf" "$CONF"
    if ! nginx -t >/dev/null 2>&1; then
      install -m 0644 -o root -g root "$TMP/nginx.conf" "$CONF"
      if [[ -f "$TMP/old-fullchain.pem" && -f "$TMP/old-privkey.pem" ]]; then
        install -m 0644 -o root -g root "$TMP/old-fullchain.pem" "$CERT_DIR/fullchain.pem"
        install -m 0600 -o root -g root "$TMP/old-privkey.pem" "$CERT_DIR/privkey.pem"
      else
        rm -rf "$CERT_DIR"
      fi
      die "nginx rejected the uploaded certificate configuration"
    fi
    systemctl reload nginx
    echo "custom certificate installed for $DOMAIN"
    ;;

  cert-custom-delete)
    DOMAIN="${1:-}"; valid_domain "$DOMAIN"
    CONF="$NGINX_AV/$DOMAIN"; CERT_DIR="/etc/nebula-panel/certs/$DOMAIN"
    if [[ -f "$CONF" ]]; then
      TMP="$(mktemp)"; trap 'rm -f "$TMP"' EXIT
      cp "$CONF" "$TMP"
      sed -i '/# NEBULA_CUSTOM_SSL_BEGIN/,/# NEBULA_CUSTOM_SSL_END/d' "$CONF"
      nginx -t >/dev/null 2>&1 || { cp "$TMP" "$CONF"; die "nginx config test failed"; }
      systemctl reload nginx
    fi
    rm -rf "$CERT_DIR"
    echo "custom certificate removed for $DOMAIN"
    ;;

  # php-ini <version> <key> <value>  (whitelisted keys; sets fpm+cli, reloads fpm)
  php-ini)
    VER="${1:-}"; KEY="${2:-}"; VAL="${3:-}"
    valid_php "$VER"
    case "$KEY" in
      memory_limit|upload_max_filesize|post_max_size|max_execution_time|max_input_time|max_input_vars|display_errors|log_errors|max_file_uploads|default_socket_timeout|opcache.enable|opcache.memory_consumption|opcache.max_accelerated_files|opcache.validate_timestamps|xdebug.mode|xdebug.client_port|xdebug.start_with_request) ;;
      *) die "ini key not allowed" ;;
    esac
    [[ "$VAL" =~ ^[A-Za-z0-9_.,-]+$ ]] || die "invalid value"
    KEY_RE="${KEY//./\\.}"
    changed=0
    for SAPI in fpm cli; do
      INI="/etc/php/${VER}/${SAPI}/php.ini"
      [[ -f "$INI" ]] || continue
      if grep -qE "^;?[[:space:]]*${KEY_RE}[[:space:]]*=" "$INI"; then
        sed -i -E "s|^;?[[:space:]]*(${KEY_RE})[[:space:]]*=.*|\1 = ${VAL}|" "$INI"
      else
        echo "${KEY} = ${VAL}" >> "$INI"
      fi
      changed=1
    done
    [[ "$changed" == 1 ]] || die "no php.ini found for ${VER}"
    # Do not reload the FPM pool synchronously: this helper is normally called
    # by that same pool, and tearing down its FastCGI request produces an Nginx
    # 502 even though the ini edit succeeded. Schedule the reload after the API
    # response has had time to reach the browser.
    schedule_php_service reload "$VER"
    echo "set ${KEY}=${VAL} for php ${VER}; reload scheduled"
    ;;

  # ==========================================================================
  # Mail stack — Postfix (MTA) + Dovecot (IMAP/POP3/LMTP + SASL) + OpenDKIM.
  #
  # Virtual, file-backed mailboxes (no SQL): all state lives under
  # /etc/nebula-mail and is regenerated wholesale by `mail-apply` from data the
  # panel owns, so there is never drift between the panel and the running MTA.
  # ==========================================================================
  mail-setup)
    export DEBIAN_FRONTEND=noninteractive
    HOSTFQDN="$(hostname -f 2>/dev/null || hostname)"
    echo "Installing mail packages (Postfix, Dovecot, OpenDKIM)…"
    echo "postfix postfix/main_mailer_type select Internet Site" | debconf-set-selections
    echo "postfix postfix/mailname string ${HOSTFQDN}" | debconf-set-selections
    apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 update
    apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 install -y \
      postfix dovecot-core dovecot-imapd dovecot-pop3d dovecot-lmtpd \
      opendkim opendkim-tools ssl-cert || die "mail package installation failed"

    echo "Creating virtual mail user and directories…"
    getent group vmail >/dev/null 2>&1 || groupadd -g "$MAIL_VGID" vmail
    getent passwd vmail >/dev/null 2>&1 || \
      useradd -r -g vmail -u "$MAIL_VUID" -d "$MAIL_STORE" -s /usr/sbin/nologin vmail
    install -d -m 0700 -o vmail -g vmail "$MAIL_STORE"
    install -d -m 0750 -o root -g root "$MAIL_DIR"
    install -d -m 0750 -o opendkim -g opendkim "$DKIM_DIR" 2>/dev/null || install -d -m 0750 "$DKIM_DIR"
    : > "$MAIL_DIR/vdomains"; : > "$MAIL_DIR/vmailbox"; : > "$MAIL_DIR/valias"
    : > "$MAIL_DIR/dovecot-users"; chmod 0640 "$MAIL_DIR/dovecot-users"
    chgrp dovecot "$MAIL_DIR/dovecot-users" 2>/dev/null || true
    postmap "$MAIL_DIR/vdomains" "$MAIL_DIR/vmailbox" "$MAIL_DIR/valias"

    echo "Configuring Postfix…"
    postconf -e "myhostname = ${HOSTFQDN}"
    postconf -e "inet_interfaces = all"
    postconf -e "inet_protocols = all"
    postconf -e "smtpd_banner = \$myhostname ESMTP"
    postconf -e "virtual_mailbox_domains = hash:$MAIL_DIR/vdomains"
    postconf -e "virtual_mailbox_base = $MAIL_STORE"
    postconf -e "virtual_mailbox_maps = hash:$MAIL_DIR/vmailbox"
    postconf -e "virtual_alias_maps = hash:$MAIL_DIR/valias"
    postconf -e "virtual_minimum_uid = $MAIL_VUID"
    postconf -e "virtual_uid_maps = static:$MAIL_VUID"
    postconf -e "virtual_gid_maps = static:$MAIL_VGID"
    postconf -e "virtual_transport = lmtp:unix:private/dovecot-lmtp"
    postconf -e "smtpd_sasl_type = dovecot"
    postconf -e "smtpd_sasl_path = private/auth"
    postconf -e "smtpd_tls_security_level = may"
    postconf -e "smtpd_tls_cert_file = /etc/ssl/certs/ssl-cert-snakeoil.pem"
    postconf -e "smtpd_tls_key_file = /etc/ssl/private/ssl-cert-snakeoil.key"
    postconf -e "smtp_tls_security_level = may"
    postconf -e "milter_default_action = accept"
    postconf -e "milter_protocol = 6"
    postconf -e "smtpd_milters = inet:localhost:8891"
    postconf -e "non_smtpd_milters = inet:localhost:8891"
    # Submission (587) with SASL for authenticated mail clients.
    postconf -M submission/inet="submission inet n - y - - smtpd"
    postconf -P "submission/inet/syslog_name=postfix/submission"
    postconf -P "submission/inet/smtpd_tls_security_level=may"
    postconf -P "submission/inet/smtpd_sasl_auth_enable=yes"
    postconf -P "submission/inet/smtpd_sasl_type=dovecot"
    postconf -P "submission/inet/smtpd_sasl_path=private/auth"
    postconf -P "submission/inet/smtpd_reject_unlisted_recipient=no"
    postconf -P "submission/inet/smtpd_relay_restrictions=permit_sasl_authenticated,reject"
    postconf -P "submission/inet/milter_macro_daemon_name=ORIGINATING"

    echo "Configuring Dovecot…"
    # Make sure the self-signed cert Dovecot references actually exists, or
    # `ssl = yes` prevents the daemon from starting (and every login then fails).
    if [[ ! -f /etc/ssl/certs/ssl-cert-snakeoil.pem ]] && command -v make-ssl-cert >/dev/null 2>&1; then
      make-ssl-cert generate-default-snakeoil --force-overwrite || true
    fi
    # Disable the distro's *system* auth (PAM/passwd) so our virtual passwd-file
    # is the sole, authoritative source. Leaving system auth enabled adds a
    # competing passdb/userdb that can shadow virtual mailboxes and break login.
    if [[ -f /etc/dovecot/conf.d/10-auth.conf ]]; then
      sed -i -E 's|^[[:space:]]*!include auth-system\.conf\.ext|#!include auth-system.conf.ext|' \
        /etc/dovecot/conf.d/10-auth.conf
    fi
    cat > /etc/dovecot/conf.d/99-nebula.conf <<EOF
# Managed by Nebula Panel — do not edit by hand.
protocols = imap pop3 lmtp
mail_location = maildir:$MAIL_STORE/%d/%n
mail_uid = vmail
mail_gid = vmail
first_valid_uid = $MAIL_VUID
last_valid_uid = $MAIL_VUID
disable_plaintext_auth = no
auth_mechanisms = plain login
passdb {
  driver = passwd-file
  args = scheme=SHA512-CRYPT username_format=%u $MAIL_DIR/dovecot-users
}
userdb {
  driver = static
  args = uid=vmail gid=vmail home=$MAIL_STORE/%d/%n
}
service lmtp {
  unix_listener /var/spool/postfix/private/dovecot-lmtp {
    mode = 0600
    user = postfix
    group = postfix
  }
}
service auth {
  unix_listener /var/spool/postfix/private/auth {
    mode = 0660
    user = postfix
    group = postfix
  }
  unix_listener auth-userdb {
    mode = 0600
    user = vmail
  }
}
ssl = yes
ssl_cert = </etc/ssl/certs/ssl-cert-snakeoil.pem
ssl_key = </etc/ssl/private/ssl-cert-snakeoil.key
EOF

    echo "Configuring OpenDKIM…"
    install -d -m 0755 /run/opendkim -o opendkim -g opendkim 2>/dev/null || true
    printf '127.0.0.1\nlocalhost\n::1\n' > "$DKIM_DIR/TrustedHosts"
    touch "$DKIM_DIR/KeyTable" "$DKIM_DIR/SigningTable"
    cat > /etc/opendkim.conf <<EOF
# Managed by Nebula Panel — do not edit by hand.
Syslog                  yes
UMask                   002
Mode                    sv
SubDomains              no
AutoRestart             yes
AutoRestartRate         10/1h
Canonicalization        relaxed/simple
OversignHeaders         From
Socket                  inet:8891@localhost
PidFile                 /run/opendkim/opendkim.pid
UserID                  opendkim
KeyTable                $DKIM_DIR/KeyTable
SigningTable            refile:$DKIM_DIR/SigningTable
ExternalIgnoreList      $DKIM_DIR/TrustedHosts
InternalHosts           $DKIM_DIR/TrustedHosts
EOF
    if [[ -f /etc/default/opendkim ]]; then
      sed -i 's|^SOCKET=.*|SOCKET="inet:8891@localhost"|' /etc/default/opendkim
      grep -q '^SOCKET=' /etc/default/opendkim || echo 'SOCKET="inet:8891@localhost"' >> /etc/default/opendkim
    fi
    chown -R opendkim:opendkim "$DKIM_DIR" 2>/dev/null || true

    systemctl enable --now opendkim >/dev/null 2>&1 || systemctl restart opendkim || true
    systemctl restart dovecot || die "dovecot failed to start"
    systemctl restart postfix || die "postfix failed to start"
    systemctl enable dovecot postfix >/dev/null 2>&1 || true

    # Open the standard mail ports when UFW is active so delivery works.
    if command -v ufw >/dev/null 2>&1 && ufw status 2>/dev/null | grep -q "Status: active"; then
      for P in 25 587 465 143 993 110 995; do ufw allow "${P}/tcp" >/dev/null 2>&1 || true; done
      echo "opened mail ports in UFW"
    fi
    echo "mail stack ready"
    ;;

  # mail-status  ->  key=value status lines parsed by the panel.
  mail-status)
    svc() { systemctl is-active "$1" 2>/dev/null || echo inactive; }
    INSTALLED=no
    [[ -d "$MAIL_DIR" ]] && command -v postfix >/dev/null 2>&1 && command -v dovecot >/dev/null 2>&1 && INSTALLED=yes
    IP="$(hostname -I 2>/dev/null | awk '{print $1}')"
    echo "installed=$INSTALLED"
    echo "postfix=$(svc postfix)"
    echo "dovecot=$(svc dovecot)"
    echo "opendkim=$(svc opendkim)"
    echo "hostname=$(hostname -f 2>/dev/null || hostname)"
    echo "ip=${IP:-}"
    ;;

  # mail-apply <domains_b64> <accounts_b64> <aliases_b64>
  #   domains_b64  : newline list of mail domains
  #   accounts_b64 : newline of  email<TAB>{SHA512-CRYPT}$6$hash
  #   aliases_b64  : newline of  alias@domain<TAB>destination@domain
  # Rebuilds every map from scratch, ensures DKIM keys + maildirs, reloads.
  mail-apply)
    [[ -d "$MAIL_DIR" ]] || die "mail stack is not installed; run mail-setup first"
    DOMAINS_B64="${1:-}"; ACCOUNTS_B64="${2:-}"; ALIASES_B64="${3:-}"
    for v in "$DOMAINS_B64" "$ACCOUNTS_B64" "$ALIASES_B64"; do
      [[ -z "$v" || "$v" =~ ^[A-Za-z0-9+/=]+$ ]] || die "invalid input encoding"
    done
    TMP="$(mktemp -d)"; trap 'rm -rf "$TMP"' EXIT
    printf '%s' "$DOMAINS_B64"  | base64 -d > "$TMP/domains"  2>/dev/null || : > "$TMP/domains"
    printf '%s' "$ACCOUNTS_B64" | base64 -d > "$TMP/accounts" 2>/dev/null || : > "$TMP/accounts"
    printf '%s' "$ALIASES_B64"  | base64 -d > "$TMP/aliases"  2>/dev/null || : > "$TMP/aliases"

    : > "$TMP/vdomains"; : > "$TMP/vmailbox"; : > "$TMP/valias"; : > "$TMP/dovecot-users"
    # Skip malformed rows rather than aborting: a single bad entry must never
    # take down the whole mail configuration (which would break login for every
    # otherwise-valid mailbox). Rejected rows are reported on stderr.
    declare -A KNOWN_DOMAIN=()
    while IFS= read -r d; do
      [[ -z "$d" ]] && continue
      if [[ ! "$d" =~ ^[a-zA-Z0-9]([a-zA-Z0-9.-]{0,251}[a-zA-Z0-9])?$ ]]; then
        echo "skipping invalid mail domain: $d" >&2; continue
      fi
      KNOWN_DOMAIN["$d"]=1
      printf '%s OK\n' "$d" >> "$TMP/vdomains"
    done < "$TMP/domains"

    while IFS=$'\t' read -r email hash; do
      [[ -z "$email" ]] && continue
      if [[ ! "$email" =~ ^[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+$ ]]; then
        echo "skipping invalid account address: $email" >&2; continue
      fi
      if [[ ! "$hash" =~ ^\{SHA512-CRYPT\}\$6\$[./A-Za-z0-9]{1,32}\$[./A-Za-z0-9]{1,200}$ ]]; then
        echo "skipping account with invalid password hash: $email" >&2; continue
      fi
      local_part="${email%@*}"; domain_part="${email#*@}"
      if [[ -z "${KNOWN_DOMAIN[$domain_part]:-}" ]]; then
        echo "skipping account whose domain is not in the domain list: $email" >&2; continue
      fi
      if [[ ! "$local_part" =~ ^[a-zA-Z0-9._%+-]+$ ]]; then
        echo "skipping account with invalid local part: $email" >&2; continue
      fi
      printf '%s %s/%s/\n' "$email" "$domain_part" "$local_part" >> "$TMP/vmailbox"
      printf '%s:%s:%s:%s::%s/%s/%s::\n' "$email" "$hash" "$MAIL_VUID" "$MAIL_VGID" "$MAIL_STORE" "$domain_part" "$local_part" >> "$TMP/dovecot-users"
    done < "$TMP/accounts"

    while IFS=$'\t' read -r from to; do
      [[ -z "$from" ]] && continue
      if [[ ! "$from" =~ ^[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+$ ]]; then
        echo "skipping invalid alias address: $from" >&2; continue
      fi
      if [[ ! "$to" =~ ^[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+$ ]]; then
        echo "skipping invalid alias destination: $to" >&2; continue
      fi
      printf '%s %s\n' "$from" "$to" >> "$TMP/valias"
    done < "$TMP/aliases"

    # Install the regenerated maps atomically, then rebuild the hash databases.
    install -m 0644 -o root -g root "$TMP/vdomains" "$MAIL_DIR/vdomains"
    install -m 0644 -o root -g root "$TMP/vmailbox" "$MAIL_DIR/vmailbox"
    install -m 0644 -o root -g root "$TMP/valias"   "$MAIL_DIR/valias"
    install -m 0640 -o root -g root "$TMP/dovecot-users" "$MAIL_DIR/dovecot-users"
    chgrp dovecot "$MAIL_DIR/dovecot-users" 2>/dev/null || true
    postmap "$MAIL_DIR/vdomains" "$MAIL_DIR/vmailbox" "$MAIL_DIR/valias"

    # Ensure a Maildir exists for every mailbox (Dovecot also autocreates).
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      sub="${line#* }"
      install -d -m 0700 -o vmail -g vmail "$MAIL_STORE/${sub%/}" \
        "$MAIL_STORE/${sub%/}/cur" "$MAIL_STORE/${sub%/}/new" "$MAIL_STORE/${sub%/}/tmp"
    done < "$MAIL_DIR/vmailbox"

    # Rebuild DKIM key tables from the domain list, generating any missing keys.
    : > "$TMP/KeyTable"; : > "$TMP/SigningTable"
    for d in "${!KNOWN_DOMAIN[@]}"; do
      KDIR="$DKIM_DIR/$d"
      if [[ ! -f "$KDIR/mail.private" ]]; then
        install -d -m 0750 "$KDIR"
        # Best-effort: a DKIM hiccup must not abort applying mailboxes/aliases
        # (which would otherwise break login). Domains without a key simply have
        # no DKIM signing until the key can be generated.
        if ! opendkim-genkey -b 2048 -d "$d" -D "$KDIR" -s mail >/dev/null 2>&1; then
          echo "warning: DKIM key generation failed for $d — signing disabled for it" >&2
          continue
        fi
        chown -R opendkim:opendkim "$KDIR" 2>/dev/null || true
        chmod 0600 "$KDIR/mail.private" 2>/dev/null || true
      fi
      [[ -f "$KDIR/mail.private" ]] || continue
      printf 'mail._domainkey.%s %s:mail:%s/mail.private\n' "$d" "$d" "$KDIR" >> "$TMP/KeyTable"
      printf '*@%s mail._domainkey.%s\n' "$d" "$d" >> "$TMP/SigningTable"
    done
    install -m 0644 "$TMP/KeyTable"    "$DKIM_DIR/KeyTable"
    install -m 0644 "$TMP/SigningTable" "$DKIM_DIR/SigningTable"
    chown -R opendkim:opendkim "$DKIM_DIR" 2>/dev/null || true

    systemctl reload opendkim 2>/dev/null || systemctl restart opendkim 2>/dev/null || true
    systemctl reload postfix 2>/dev/null || systemctl restart postfix 2>/dev/null || true
    systemctl reload dovecot 2>/dev/null || true
    echo "mail configuration applied"
    ;;

  # mail-dkim <domain>  ->  selector=..  value=..  (the public TXT record body)
  mail-dkim)
    DOMAIN="${1:-}"; valid_domain "$DOMAIN"
    KDIR="$DKIM_DIR/$DOMAIN"
    TXT="$KDIR/mail.txt"
    # Generate the key on demand if it is missing, so the panel's DNS tab can
    # always show a DKIM record once the mail stack is installed. (mail-apply
    # normally creates it, but a domain added before the stack — or a failed
    # earlier generation — can leave it absent.)
    if [[ ! -f "$TXT" ]] && command -v opendkim-genkey >/dev/null 2>&1; then
      install -d -m 0750 "$KDIR" 2>/dev/null || true
      if opendkim-genkey -b 2048 -d "$DOMAIN" -D "$KDIR" -s mail >/dev/null 2>&1; then
        chown -R opendkim:opendkim "$KDIR" 2>/dev/null || true
        chmod 0600 "$KDIR/mail.private" 2>/dev/null || true
      fi
    fi
    [[ -f "$TXT" ]] || die "no DKIM key for $DOMAIN; install the mail stack, then add the domain"
    # opendkim-genkey writes the record split across quoted strings; join them
    # back into one continuous value the panel can present and publish.
    VALUE="$(grep -o '"[^"]*"' "$TXT" | sed 's/^"//; s/"$//' | tr -d '\n' | tr -d ' \t')"
    [[ -n "$VALUE" ]] || die "could not read DKIM public key"
    echo "selector=mail"
    echo "value=$VALUE"
    ;;

  # roundcube-install <targetdir>
  roundcube-install)
    TARGET="${1:-}"; valid_path "$TARGET"
    command -v curl >/dev/null || die "curl not installed"
    RC_VER=1.6.9
    export DEBIAN_FRONTEND=noninteractive
    # Roundcube's runtime dependencies (SQLite backend keeps setup zero-config).
    PHP_VER="$(ls -d /etc/php/*/fpm 2>/dev/null | sort -V | tail -1 | awk -F/ '{print $4}')"
    if [[ -n "$PHP_VER" ]]; then
      apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 install -y \
        "php${PHP_VER}-sqlite3" "php${PHP_VER}-intl" "php${PHP_VER}-xml" \
        "php${PHP_VER}-mbstring" "php${PHP_VER}-zip" "php${PHP_VER}-gd" \
        "php${PHP_VER}-curl" "php${PHP_VER}-imagick" >/dev/null 2>&1 || true
    fi
    TMP="$(mktemp -d)"; trap 'rm -rf "$TMP"' EXIT
    curl -fL --show-error --progress-bar -o "$TMP/rc.tar.gz" \
      "https://github.com/roundcube/roundcubemail/releases/download/${RC_VER}/roundcubemail-${RC_VER}-complete.tar.gz" \
      || die "roundcube download failed"
    tar -xzf "$TMP/rc.tar.gz" -C "$TMP" || die "extract failed"
    SRC="$(find "$TMP" -maxdepth 1 -type d -name 'roundcubemail-*' | head -1)"
    [[ -n "$SRC" ]] || die "archive layout unexpected"
    mkdir -p "$TARGET"; cp -a "$SRC"/. "$TARGET"/
    rm -rf "$TARGET/installer"
    install -d -m 0750 -o www-data -g www-data /var/lib/nebula-mail
    DESKEY="$(od -An -N24 -tx1 /dev/urandom | tr -d ' \n')"
    cat > "$TARGET/config/config.inc.php" <<EOF
<?php
/* Managed by Nebula Panel. */
\$config = [];
\$config['db_dsnw'] = 'sqlite:////var/lib/nebula-mail/roundcube.db?mode=0640';
\$config['imap_host'] = 'localhost:143';
\$config['smtp_host'] = 'localhost:587';
\$config['smtp_user'] = '%u';
\$config['smtp_pass'] = '%p';
\$config['imap_conn_options'] = ['ssl' => ['verify_peer' => false, 'verify_peer_name' => false]];
\$config['smtp_conn_options'] = ['ssl' => ['verify_peer' => false, 'verify_peer_name' => false]];
\$config['support_url'] = '';
\$config['product_name'] = 'Nebula Webmail';
\$config['des_key'] = '${DESKEY:0:24}';
\$config['plugins'] = ['archive', 'zipdownload', 'managesieve'];
\$config['skin'] = 'elastic';
\$config['enable_installer'] = false;
\$config['log_dir'] = '/var/lib/nebula-mail/rc-logs/';
\$config['temp_dir'] = '/var/lib/nebula-mail/rc-temp/';
EOF
    install -d -m 0750 -o www-data -g www-data /var/lib/nebula-mail/rc-logs /var/lib/nebula-mail/rc-temp
    chown -R www-data:www-data "$TARGET"
    echo "roundcube installed at $TARGET"
    ;;

  # roundcube-remove <targetdir>
  roundcube-remove)
    TARGET="${1:-}"; valid_path "$TARGET"
    [[ "$TARGET" == "/" || "$TARGET" == "/var/www" ]] && die "refusing"
    [[ -f "$TARGET/config/config.inc.php" ]] || die "not a roundcube dir"
    rm -rf "$TARGET"
    echo "removed $TARGET"
    ;;

  # snappymail-install <targetdir>  — SnappyMail, the maintained Rainloop fork.
  # Ships as a pre-built tarball (no Composer). Data is stored OUTSIDE the
  # webroot and a catch-all domain is pre-seeded so mailboxes authenticate
  # against this server's local Dovecot/Postfix with zero manual setup.
  snappymail-install)
    TARGET="${1:-}"; valid_path "$TARGET"
    command -v curl >/dev/null || die "curl not installed"
    export DEBIAN_FRONTEND=noninteractive
    PHP_VER="$(ls -d /etc/php/*/fpm 2>/dev/null | sort -V | tail -1 | awk -F/ '{print $4}')"
    if [[ -n "$PHP_VER" ]]; then
      apt-get -o Dpkg::Use-Pty=0 -o APT::Color=0 install -y \
        "php${PHP_VER}-curl" "php${PHP_VER}-xml" "php${PHP_VER}-mbstring" \
        "php${PHP_VER}-zip" "php${PHP_VER}-intl" "php${PHP_VER}-gd" \
        "php${PHP_VER}-sqlite3" >/dev/null 2>&1 || true
    fi
    # Resolve the latest release tarball from GitHub (robust to version bumps).
    URL="$(curl -fsSL -H 'User-Agent: NebulaPanel' \
      https://api.github.com/repos/the-djmaze/snappymail/releases/latest 2>/dev/null \
      | grep -oE 'https://[^"]+/snappymail-[0-9.]+\.tar\.gz' | head -1)"
    [[ -n "$URL" ]] || die "could not resolve the latest SnappyMail release (GitHub rate limit?)"
    TMP="$(mktemp -d)"; trap 'rm -rf "$TMP"' EXIT
    curl -fL --show-error --progress-bar -o "$TMP/sm.tar.gz" "$URL" || die "snappymail download failed"
    mkdir -p "$TARGET"
    # The release tarball extracts directly to the app root (index.php, snappymail/, data/).
    tar -xzf "$TMP/sm.tar.gz" -C "$TARGET" || die "extract failed"
    [[ -f "$TARGET/index.php" ]] || die "unexpected SnappyMail archive layout"
    # Keep runtime data OUTSIDE the webroot (nginx has no .htaccess to hide it).
    DATA_PATH="/var/lib/nebula-mail/snappymail"
    install -d -m 0750 -o www-data -g www-data /var/lib/nebula-mail "$DATA_PATH"
    cat > "$TARGET/include.php" <<PHPEOF
<?php
/* Managed by Nebula Panel — store SnappyMail data outside the webroot. */
define('APP_DATA_FOLDER_PATH', '$DATA_PATH/');
PHPEOF
    # Catch-all domain: every mailbox logs in against local IMAP/SMTP.
    install -d -m 0750 -o www-data -g www-data "$DATA_PATH/_data_/_default_/domains"
    cat > "$DATA_PATH/_data_/_default_/domains/default.ini" <<'INIEOF'
imap_host = "127.0.0.1"
imap_port = 143
imap_secure = "None"
imap_short_login = Off
smtp_host = "127.0.0.1"
smtp_port = 587
smtp_secure = "None"
smtp_short_login = Off
smtp_use_auth = On
sieve_use = Off
white_list = ""
INIEOF
    chown -R www-data:www-data "$TARGET" "$DATA_PATH"
    echo "snappymail installed at $TARGET"
    ;;

  # webmail-remove <targetdir>  — generic removal for any panel-managed webmail
  # directory (Roundcube or SnappyMail). Confined by the managed naming scheme.
  webmail-remove)
    TARGET="${1:-}"; valid_path "$TARGET"
    base="$(basename "$TARGET")"
    [[ "$base" =~ ^(webmail|snappymail)-[0-9a-fA-F]+$ ]] || die "not a managed webmail dir"
    [[ -f "$TARGET/index.php" ]] || die "not a webmail dir"
    rm -rf "$TARGET"
    echo "removed $TARGET"
    ;;

  *)
    die "unknown command: $CMD"
    ;;
esac
